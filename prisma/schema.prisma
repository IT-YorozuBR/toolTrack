// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tool {
  id                String   @id @default(cuid())
  code              String   @unique
  description       String?
  press             String
  line              String?
  shotsPerStroke    Int
  currentStrokes    Int      @default(0)
  preventiveLimit   Int      @default(50000)
  warningLimit      Int      @default(45000)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  bomItems           BomItem[]
  maintenanceRecords MaintenanceRecord[]
  monthlySnapshots   ToolMonthlyStrokeSnapshot[]
  strokeReadings     ToolStrokeReading[]
}

model Project {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectProducts ProjectProduct[]
  forecasts       ProjectForecast[]
}

model ProjectProduct {
  id        String  @id @default(cuid())
  projectId String
  productId String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([projectId, productId])
}

model ProjectForecast {
  id              String   @id @default(cuid())
  projectId       String
  referenceMonth  DateTime
  plannedQuantity Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, referenceMonth])
}

model Product {
  id          String   @id @default(cuid())
  code        String   @unique
  modelo      String?
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bomItems        BomItem[]
  forecasts       ProductionForecast[]
  projectProducts ProjectProduct[]
}

model BomItem {
  id           String   @id @default(cuid())
  productId    String
  toolId       String
  quantityUsed Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tool    Tool    @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([productId, toolId])
}

model ProductionForecast {
  id              String   @id @default(cuid())
  productId       String
  referenceMonth  DateTime
  plannedQuantity Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, referenceMonth])
}

model MaintenanceRecord {
  id                   String   @id @default(cuid())
  toolId               String
  maintenanceDate      DateTime
  strokesAtMaintenance Int
  maintenanceType      String
  responsible          String?
  notes                String?
  resetCounter         Boolean  @default(true)
  createdAt            DateTime @default(now())

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)
}

model ToolMonthlyStrokeSnapshot {
  id             String   @id @default(cuid())
  toolId         String
  referenceMonth DateTime
  strokes        Int
  forecastStrokes Int?
  actualStrokes  Int?
  cycleStartedAt DateTime?
  source         String   @default("forecast")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([toolId, referenceMonth])
  @@index([referenceMonth])
}

model ToolStrokeReading {
  id           String   @id @default(cuid())
  toolId       String
  readingDate  DateTime
  cycleStrokes Int
  notes        String?
  createdAt    DateTime @default(now())

  tool Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId, readingDate])
}
